  "item": [
    {
      "name": "Listar usuários",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {\r",
              "pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Tempo de resposta\", function () {\r",
              "pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "pm.test(\"Retornou usuarios\", function () {\r",
              "const usuarios = pm.response.json();\r",
              "pm.expect(usuarios.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test (\"Primeiro usuário tem nome\", function(){\r",
              "const usuarios = pm.response.json();\r",
              "pm.expect(usuarios[0]).to.have.property( \"name\" );\r",
              "})\r",
              "\r",
              "pm.test (\"Primeiro usuário tem e-mail\", function(){\r",
              "const usuarios = pm.response.json();\r",
              "pm.expect(usuarios[0]).to.have.property( \"email\" );\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
            "typicode",
            "com"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
